# Terraform variables for WealthTrack Agent Cloud Run deployment
# Copy this to terraform.tfvars and fill in your values

project_id      = "your-gcp-project-id"
region          = "us-central1"
firestore_location = "nam5"

# Production model (Tier 3)
model           = "gemini-3.1-pro-preview"

# Get from: https://ai.google.dev/gemini-api/docs/api-key
gemini_api_key  = "your-gemini-api-key"

# Optional: Get from Arize/Phoenix for trace collection
phoenix_api_key = ""

# Cloud Run scaling
min_instances   = 0   # Scales to zero when idle (saves cost)
max_instances   = 10
